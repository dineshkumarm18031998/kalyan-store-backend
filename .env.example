# ══════════════════════════════════════════════════════════════
# KALYAN STORE BACKEND — Environment Variables
# Copy this to .env for local dev (never commit .env to git)
# ══════════════════════════════════════════════════════════════

# ── Supabase Database (Transaction Pooler — REQUIRED) ─────────
# Get from: Supabase → Settings → Database → Transaction pooler → URI
# Use port 6543 (NOT 5432)
# Format: postgresql://postgres.YOURREF:YOURPASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres
# DO NOT add ?sslmode=no-verify — ssl is handled in db/index.js
DATABASE_URL=postgresql://postgres.btwgjlwrpqdbtpjkgomp:YOURPASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=kalyan2024secret
JWT_EXPIRES_IN=7d

# ── Server ─────────────────────────────────────────────────────
PORT=10000
NODE_ENV=production
